INDEX_FILE = "/media/SSD/Anil/ENA/Index/Hisat2/genome_tran"
COUNT_DIR = "/media/SSD/Anil/ENA/GSE148434/PE/featureCounts"
GTF_FILE = "/media/SSD/Anil/ENA/Index/Hisat2/Homo_sapiens.GRCh38.112.gtf"
THREADS = 128

import glob
import os

SAMPLES = glob_wildcards(f"{FASTQ_DIR}" + "/{sample}_1.fastq.gz").sample


############################################
# Final rule
############################################

rule all:
    input:
        expand(f"{COUNT_DIR}/{{sample}}/{{sample}}.txt", sample=SAMPLES)


